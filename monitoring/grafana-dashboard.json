{
  "__inputs": [],
  "__requires": [],
  "title": "Smart Factory Supervisor",
  "description": "Real-time IIoT dashboard for the Smart Factory Supervisor showcase",
  "tags": ["iiot", "robotics", "factory"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Robot Uptime",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "uptime_seconds",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Alert Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "lineInterpolation": "stepAfter",
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(alerts_critical_total[5m])",
          "legendFormat": "Critical alerts/s",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Active Robot Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "robots_active_total",
          "legendFormat": "Active robots",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "values": false
        },
        "text": {},
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "OEE Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg(oee_percent) by (robot_id)",
          "legendFormat": "{{robot_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "type": "prometheus", "uid": "prometheus" }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Critical Alerts",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "alerts_critical_total > 0",
        "enable": true,
        "iconColor": "red"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1
}
