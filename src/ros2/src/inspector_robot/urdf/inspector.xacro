<?xml version="1.0"?>
<robot name="inspector_robot" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- Mobile base -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.35 0.25 0.12"/></geometry>
      <material name="purple">
        <color rgba="0.5 0.2 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry><box size="0.35 0.25 0.12"/></geometry>
    </collision>
    <inertial>
      <mass value="18.0"/>
      <inertia ixx="0.15" ixy="0.0" ixz="0.0" iyy="0.15" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Wheels (visual only) -->
  <joint name="left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.15 -0.15 -0.06"/>
  </joint>
  <link name="left_wheel">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.15 0.15 -0.06"/>
  </joint>
  <link name="right_wheel">
    <visual>
      <geometry><cylinder radius="0.06" length="0.04"/></geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <!-- Sensor mast -->
  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mast"/>
    <origin xyz="0.05 0 0.12"/>
  </joint>
  <link name="mast">
    <visual>
      <geometry><cylinder radius="0.02" length="0.2"/></geometry>
      <material name="silver">
        <color rgba="0.7 0.7 0.7 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- Camera head -->
  <joint name="head_joint" type="revolute">
    <parent link="mast"/>
    <child link="head"/>
    <origin xyz="0 0 0.2"/>
    <axis xyz="0 0 1"/>
    <limit effort="50" velocity="1.0" lower="-3.14" upper="3.14"/>
  </joint>
  <link name="head">
    <visual>
      <geometry><sphere radius="0.06"/></geometry>
      <material name="purple_light">
        <color rgba="0.6 0.3 0.9 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.005" ixy="0.0" ixz="0.0" iyy="0.005" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <!-- Camera lens -->
  <joint name="camera_joint" type="fixed">
    <parent link="head"/>
    <child link="camera_lens"/>
    <origin xyz="0.04 0 0"/>
  </joint>
  <link name="camera_lens">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="lens">
        <color rgba="0.0 0.0 0.8 0.8"/>
      </material>
    </visual>
  </link>
</robot>
