{
  "never_touch": [
    "secrets/**",
    "src/.env",
    "src/envs/**/.env",
    "src/envs/**/.env.local",
    "**/*.pem",
    "**/*.key",
    "**/*.crt"
  ],

  "read_only": [
    "data/**",
    "logs/**",
    "**/.env.template",
    "**/.env.example",
    ".agent/knowledge/**"
  ],

  "require_approval": [
    ".agent/access-permissions.json",
    ".gitattributes",
    ".gitignore",
    "opencode.json",
    "src/Caddyfile",
    "src/docker-compose.yaml",
    "**/Dockerfile",
    "**/pyproject.toml"
  ],
  
  "writable": [
    "src/**/*.cpp",
    "src/**/*.hpp",
    "src/**/*.h",
    "scripts/**/*.py",
    "src/**/*.py",
    "src/**/*.ts",
    "src/**/*.tsx",
    "**/*.md",
    "**/*.svg",
    ".agent/**",
    "**/CMakeLists.txt",
    "**/.dockerignore"
  ]
}
